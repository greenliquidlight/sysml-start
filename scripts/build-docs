#!/usr/bin/env sh
# scripts/build-docs
#
# Assembles documentation from Markdown sources and generated SVG diagrams
# into an HTML index page.
#
# Current implementation: generates a simple HTML index file at
#   generated/docs/index.html
#
# Exit codes:
#   0 — docs assembled successfully
#   1 — required source files or diagrams are missing
#
# TODO: Replace or extend this script with pandoc (or mkdocs/sphinx) to
#       produce polished multi-format output:
#
#   pandoc docs/overview.md docs/workflow.md \
#       --standalone --toc \
#       --output generated/docs/index.html
#
#   pandoc docs/overview.md docs/workflow.md \
#       --standalone --toc \
#       --output generated/docs/document.pdf
#
#   pandoc docs/overview.md docs/workflow.md \
#       --standalone \
#       --output generated/docs/document.docx

set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DOCS_DIR="$REPO_ROOT/docs"
DIAGRAMS_DIR="$REPO_ROOT/generated/diagrams"
OUTPUT_DIR="$REPO_ROOT/generated/docs"

echo "=== Documentation Build ==="
echo "Docs source:    $DOCS_DIR"
echo "Diagrams:       $DIAGRAMS_DIR"
echo "Output:         $OUTPUT_DIR"
echo ""

# ---------------------------------------------------------------------------
# Verify required source files exist
# ---------------------------------------------------------------------------
MISSING=0
for f in \
    "$DOCS_DIR/overview.md" \
    "$DOCS_DIR/workflow.md"; do
    if [ -f "$f" ]; then
        echo "  [OK] $(basename "$f")"
    else
        echo "  [MISSING] $f"
        MISSING=$((MISSING + 1))
    fi
done

for f in \
    "$DIAGRAMS_DIR/context.svg" \
    "$DIAGRAMS_DIR/artifact-flow.svg"; do
    if [ -f "$f" ]; then
        echo "  [OK] $(basename "$f")"
    else
        echo "  [MISSING] $f  (run scripts/render-diagrams first)"
        MISSING=$((MISSING + 1))
    fi
done

echo ""

if [ "$MISSING" -gt 0 ]; then
    echo "ERROR: $MISSING required file(s) missing. Doc build failed."
    exit 1
fi

# ---------------------------------------------------------------------------
# Create output directory
# ---------------------------------------------------------------------------
mkdir -p "$OUTPUT_DIR"

# ---------------------------------------------------------------------------
# Generate HTML index page
# ---------------------------------------------------------------------------
# TODO: Replace this heredoc with a pandoc/mkdocs invocation once integrated.
# The HTML below is a minimal functional page that embeds the generated SVGs
# and links to the Markdown docs.

cat > "$OUTPUT_DIR/index.html" <<HTML
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SysML2 Workflow — Documentation</title>
  <style>
    body { font-family: sans-serif; max-width: 900px; margin: 40px auto;
           padding: 0 20px; color: #212529; }
    h1   { border-bottom: 2px solid #343a40; padding-bottom: 8px; }
    h2   { border-bottom: 1px solid #dee2e6; padding-bottom: 4px; }
    nav  { background: #f8f9fa; border: 1px solid #dee2e6;
           padding: 12px 20px; border-radius: 4px; margin-bottom: 24px; }
    nav a { margin-right: 16px; text-decoration: none; color: #0d6efd; }
    nav a:hover { text-decoration: underline; }
    img  { max-width: 100%; border: 1px solid #dee2e6;
           border-radius: 4px; margin: 12px 0; }
    .notice { background: #fff3cd; border: 1px solid #ffda6a;
              border-radius: 4px; padding: 8px 16px; font-size: 0.9em; }
    footer { margin-top: 48px; padding-top: 12px;
             border-top: 1px solid #dee2e6; font-size: 0.85em; color: #6c757d; }
  </style>
</head>
<body>

<h1>SysML2 Workflow Documentation</h1>
<p class="notice">
  ⚠ <strong>Placeholder build</strong> — generated by
  <code>scripts/build-docs</code>. Replace with pandoc/mkdocs for
  polished output (see TODO comments in the script).
</p>

<nav>
  <a href="#overview">Overview</a>
  <a href="#diagrams">Diagrams</a>
  <a href="#workflow">Workflow</a>
</nav>

<h2 id="overview">Overview</h2>
<p>
  This repository implements a text-first SysML2 modeling workflow optimized
  for VS Code and easy onboarding of systems engineers. All model artifacts are
  plain-text <code>.sysml</code> files stored in Git. Rendered SVG diagrams are
  generated on day 1 and embedded in documentation.
</p>
<p>
  See <a href="../../docs/overview.md">docs/overview.md</a> for the full
  high-level description.
</p>

<h2 id="diagrams">Generated Diagrams</h2>

<h3>Context Diagram</h3>
<p>Source: <code>model/views/context-view.sysml</code></p>
<img src="../diagrams/context.svg" alt="Context Diagram"/>

<h3>Artifact Flow Diagram</h3>
<p>Source: <code>model/views/artifact-flow-view.sysml</code></p>
<img src="../diagrams/artifact-flow.svg" alt="Artifact Flow Diagram"/>

<h2 id="workflow">Workflow</h2>
<p>
  The workflow follows the sequence:
  <strong>Edit → Validate → Render → Build Docs → Review</strong>.
</p>
<p>
  See <a href="../../docs/workflow.md">docs/workflow.md</a> for the full
  workflow description including GitHub PR-based V&amp;V.
</p>

<footer>
  Generated by sysml-start &mdash; scripts/build-docs
</footer>

</body>
</html>
HTML

echo "HTML index written to: $OUTPUT_DIR/index.html"
echo ""
echo "Doc build complete."
echo "(Placeholder HTML generated — wire to pandoc/mkdocs per TODO comments above.)"
