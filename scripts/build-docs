#!/usr/bin/env sh
# scripts/build-docs
#
# Builds HTML documentation from Markdown sources using Sphinx + MyST.
# Output is written to generated/docs/.
#
# Prerequisites (installed by scripts/setup-tools):
#   pip install -r docs/requirements.txt
#
# Exit codes:
#   0 — docs built successfully
#   1 — required source files, diagrams, or tools are missing

set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DOCS_DIR="$REPO_ROOT/docs"
DIAGRAMS_DIR="$REPO_ROOT/generated/diagrams"
OUTPUT_DIR="$REPO_ROOT/generated/docs"

echo "=== Documentation Build (Sphinx + MyST) ==="
echo "Docs source:    $DOCS_DIR"
echo "Diagrams:       $DIAGRAMS_DIR"
echo "Output:         $OUTPUT_DIR"
echo ""

# ---------------------------------------------------------------------------
# Verify required source files exist
# ---------------------------------------------------------------------------
MISSING=0
for f in \
    "$DOCS_DIR/conf.py" \
    "$DOCS_DIR/index.md" \
    "$DOCS_DIR/overview.md" \
    "$DOCS_DIR/workflow.md"; do
    if [ -f "$f" ]; then
        echo "  [OK] $(basename "$f")"
    else
        echo "  [MISSING] $f"
        MISSING=$((MISSING + 1))
    fi
done

for f in \
    "$DIAGRAMS_DIR/context.svg" \
    "$DIAGRAMS_DIR/artifact-flow.svg"; do
    if [ -f "$f" ]; then
        echo "  [OK] $(basename "$f")"
    else
        echo "  [MISSING] $f  (run scripts/render-diagrams first)"
        MISSING=$((MISSING + 1))
    fi
done

echo ""

if [ "$MISSING" -gt 0 ]; then
    echo "ERROR: $MISSING required file(s) missing. Doc build failed."
    exit 1
fi

# ---------------------------------------------------------------------------
# Verify sphinx-build is available
# ---------------------------------------------------------------------------
if ! command -v sphinx-build >/dev/null 2>&1; then
    echo "ERROR: sphinx-build not found."
    echo "  Run: pip install -r docs/requirements.txt"
    exit 1
fi

# ---------------------------------------------------------------------------
# Build HTML site
# ---------------------------------------------------------------------------
mkdir -p "$OUTPUT_DIR"

echo "Running sphinx-build..."
sphinx-build -b html "$DOCS_DIR" "$OUTPUT_DIR" -q

echo ""
echo "Doc build complete."
echo "Output: $OUTPUT_DIR/index.html"
