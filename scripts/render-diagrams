#!/usr/bin/env bash
# scripts/render-diagrams
#
# Renders SysML2 model elements to SVG using the OMG SysML v2 Pilot
# Implementation JAR (SysMLInteractive) and tools/SysMLRender.java.
#
# Pipeline:
#   1. All model files are loaded into SysMLInteractive in dependency order.
#   2. Three %viz commands generate PlantUML markup for the key elements.
#   3. The REPL output is piped to SysMLRender, which extracts each
#      @startuml...@enduml block and renders it to SVG using the PlantUML
#      library bundled in the same JAR — ensuring that the skin/sysmlbw.skin
#      file (also bundled there) is resolved from the classloader.
#
# Run scripts/setup-tools first to download the JAR and compile SysMLRender.
#
# Output:
#   generated/diagrams/context.svg        — WorkflowContext::workflowContext
#   generated/diagrams/artifact-flow.svg  — WorkflowBehavior
#   generated/diagrams/requirements.svg   — WorkflowRequirements
#
# Exit codes:
#   0 — all diagrams rendered successfully
#   1 — JAR / compiled helper not found, or a diagram failed to render

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TOOLS_DIR="$REPO_ROOT/tools"
KERNEL_DIR="$TOOLS_DIR/sysml-kernel"
DIAGRAMS_DIR="$REPO_ROOT/generated/diagrams"

echo "=== SysML2 Diagram Rendering ==="
echo ""

# ---------------------------------------------------------------------------
# Locate JAR, library, and compiled renderer
# ---------------------------------------------------------------------------
JAR=$(ls "$KERNEL_DIR/sysml/"*-all.jar 2>/dev/null | head -1)
LIB="$KERNEL_DIR/sysml/sysml.library"

if [ -z "$JAR" ] || [ ! -d "$LIB" ]; then
    echo "ERROR: OMG SysML v2 kernel not found."
    echo "  Run:  scripts/setup-tools"
    exit 1
fi

if [ ! -f "$TOOLS_DIR/SysMLRender.class" ]; then
    echo "ERROR: SysMLRender.class not found."
    echo "  Run:  scripts/setup-tools"
    exit 1
fi

mkdir -p "$DIAGRAMS_DIR"

# ---------------------------------------------------------------------------
# Build the REPL input stream: load all model files then request three
# diagrams.  Each file is wrapped in bare % delimiters (multi-line mode)
# so the entire file is parsed as a single SysML element.
# ---------------------------------------------------------------------------
build_repl_input() {
    for REL in \
        "model/requirements.sysml" \
        "model/context.sysml" \
        "model/workflow.sysml" \
        "model/views/context-view.sysml" \
        "model/views/artifact-flow-view.sysml"; do
        printf '%s\n' '%'
        cat "$REPO_ROOT/$REL"
        printf '%s\n' '%'
    done
    printf '%s\n' '%viz WorkflowContext::workflowContext'  # → context.svg
    printf '%s\n' '%viz WorkflowBehavior'                  # → artifact-flow.svg
    printf '%s\n' '%viz WorkflowRequirements'              # → requirements.svg
    printf '%s\n' '%exit'
}

# ---------------------------------------------------------------------------
# Single JVM invocation: load model → generate PlantUML → render SVGs
#
# SysMLRender reads the REPL stdout, extracts @startuml blocks in order,
# and writes each to the corresponding output file.
# ---------------------------------------------------------------------------
echo "Loading model and generating diagrams..."
echo "(First run loads the standard library — expect ~15-30 s)"
echo ""

build_repl_input \
    | java -cp "$JAR" \
        org.omg.sysml.interactive.SysMLInteractive "$LIB" 2>/dev/null \
    | java -cp "$JAR:$TOOLS_DIR" SysMLRender "$DIAGRAMS_DIR" \
        context.svg artifact-flow.svg requirements.svg

echo ""
echo "All diagrams rendered to:  $DIAGRAMS_DIR"
