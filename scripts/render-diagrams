#!/usr/bin/env sh
# scripts/render-diagrams
#
# Renders SysML2 view definitions into SVG diagram files.
#
# Current implementation: generates placeholder SVGs with visible labels.
# Output directory: generated/diagrams/
#
# Exit codes:
#   0 — all diagrams generated successfully
#   1 — output directory could not be created
#
# TODO: Replace placeholder SVG generation with calls to a real SysML2
#       rendering tool, for example:
#
#   sysml2-cli render \
#       --view model/views/context-view.sysml \
#       --output generated/diagrams/context.svg
#
# or a PlantUML / Graphviz bridge driven by your .sysml view definitions.

set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DIAGRAMS_DIR="$REPO_ROOT/generated/diagrams"

echo "=== SysML2 Diagram Rendering ==="
echo "Output directory: $DIAGRAMS_DIR"
echo ""

# Ensure output directory exists
mkdir -p "$DIAGRAMS_DIR"

# ---------------------------------------------------------------------------
# Helper: write_placeholder_svg <output_path> <title> <subtitle>
# Generates a minimal valid SVG with visible labels.
# ---------------------------------------------------------------------------
write_placeholder_svg() {
    out_path="$1"
    title="$2"
    subtitle="$3"

    cat > "$out_path" <<SVG
<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg"
     width="600" height="400" viewBox="0 0 600 400">

  <!-- Background -->
  <rect width="600" height="400" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>

  <!-- Border -->
  <rect x="10" y="10" width="580" height="380"
        fill="none" stroke="#6c757d" stroke-width="1.5" stroke-dasharray="6,3"/>

  <!-- Title bar -->
  <rect x="10" y="10" width="580" height="48" fill="#343a40"/>
  <text x="300" y="40" font-family="sans-serif" font-size="16"
        font-weight="bold" fill="white" text-anchor="middle">$title</text>

  <!-- Placeholder notice -->
  <text x="300" y="90" font-family="sans-serif" font-size="12"
        fill="#6c757d" text-anchor="middle">[ Placeholder Diagram ]</text>
  <text x="300" y="110" font-family="sans-serif" font-size="11"
        fill="#6c757d" text-anchor="middle">$subtitle</text>
  <text x="300" y="130" font-family="sans-serif" font-size="11"
        fill="#6c757d" text-anchor="middle">Replace with real SysML2 renderer output</text>

  <!-- Divider -->
  <line x1="40" y1="145" x2="560" y2="145" stroke="#dee2e6" stroke-width="1"/>

  <!-- Stub nodes — context diagram -->
  <rect x="40"  y="165" width="120" height="40" rx="6" fill="#e9ecef" stroke="#adb5bd"/>
  <text x="100" y="190" font-family="sans-serif" font-size="11"
        text-anchor="middle" fill="#212529">ModelAuthor</text>

  <rect x="200" y="165" width="120" height="40" rx="6" fill="#cfe2ff" stroke="#9ec5fe"/>
  <text x="260" y="190" font-family="sans-serif" font-size="11"
        text-anchor="middle" fill="#084298">ModelRepository</text>

  <rect x="360" y="165" width="120" height="40" rx="6" fill="#d1e7dd" stroke="#a3cfbb"/>
  <text x="420" y="190" font-family="sans-serif" font-size="11"
        text-anchor="middle" fill="#0a3622">ValidationTool</text>

  <rect x="40"  y="255" width="120" height="40" rx="6" fill="#d1e7dd" stroke="#a3cfbb"/>
  <text x="100" y="280" font-family="sans-serif" font-size="11"
        text-anchor="middle" fill="#0a3622">ViewRenderer</text>

  <rect x="200" y="255" width="120" height="40" rx="6" fill="#d1e7dd" stroke="#a3cfbb"/>
  <text x="260" y="280" font-family="sans-serif" font-size="11"
        text-anchor="middle" fill="#0a3622">DocBuilder</text>

  <rect x="360" y="255" width="120" height="40" rx="6" fill="#fff3cd" stroke="#ffda6a"/>
  <text x="420" y="280" font-family="sans-serif" font-size="11"
        text-anchor="middle" fill="#664d03">Reviewer</text>

  <!-- Stub arrows -->
  <line x1="160" y1="185" x2="200" y2="185" stroke="#6c757d" stroke-width="1.5"
        marker-end="url(#arrow)"/>
  <line x1="320" y1="185" x2="360" y2="185" stroke="#6c757d" stroke-width="1.5"
        marker-end="url(#arrow)"/>
  <line x1="100" y1="205" x2="100" y2="255" stroke="#6c757d" stroke-width="1.5"
        marker-end="url(#arrow)"/>
  <line x1="260" y1="205" x2="260" y2="255" stroke="#6c757d" stroke-width="1.5"
        marker-end="url(#arrow)"/>
  <line x1="320" y1="270" x2="360" y2="270" stroke="#6c757d" stroke-width="1.5"
        marker-end="url(#arrow)"/>

  <!-- Arrow marker -->
  <defs>
    <marker id="arrow" markerWidth="8" markerHeight="8"
            refX="6" refY="3" orient="auto">
      <path d="M0,0 L0,6 L8,3 z" fill="#6c757d"/>
    </marker>
  </defs>

  <!-- Footer -->
  <text x="300" y="385" font-family="sans-serif" font-size="9"
        fill="#adb5bd" text-anchor="middle">
    Generated by scripts/render-diagrams — sysml-start
  </text>
</svg>
SVG

    echo "  [OK] $(basename "$out_path")"
}

# ---------------------------------------------------------------------------
# Generate context diagram
# ---------------------------------------------------------------------------
# TODO: Replace with real SysML2 renderer call:
#   sysml2-cli render \
#       --view "$REPO_ROOT/model/views/context-view.sysml" \
#       --output "$DIAGRAMS_DIR/context.svg"
write_placeholder_svg \
    "$DIAGRAMS_DIR/context.svg" \
    "SysML2 Workflow — Context Diagram" \
    "Source: model/views/context-view.sysml"

# ---------------------------------------------------------------------------
# Generate artifact flow diagram
# ---------------------------------------------------------------------------
# TODO: Replace with real SysML2 renderer call:
#   sysml2-cli render \
#       --view "$REPO_ROOT/model/views/artifact-flow-view.sysml" \
#       --output "$DIAGRAMS_DIR/artifact-flow.svg"
write_placeholder_svg \
    "$DIAGRAMS_DIR/artifact-flow.svg" \
    "SysML2 Workflow — Artifact Flow Diagram" \
    "Source: model/views/artifact-flow-view.sysml"

echo ""
echo "Rendering complete. Output: $DIAGRAMS_DIR"
echo "(Placeholder SVGs generated — wire to real renderer per TODO comments above.)"
